{
  "name": "ndexplorer",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest --reporter=verbose",
    "secrets": "secretlint \"**/*\"",
    "kill": "lsof -ti:4321 | xargs kill -9 2>/dev/null; echo 'Port 4321 killed...'",
    "docker:build": "docker build -t ndexplorer .",
    "docker:run": "test -f .env && docker run --rm --env-file .env -p 4321:4321 ndexplorer",
    "docker:clean": "docker rmi -f ndexplorer",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/node": "10.0.4",
    "astro": "6.1.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@secretlint/secretlint-rule-pattern": "11.4.0",
    "@secretlint/secretlint-rule-preset-recommend": "11.4.0",
    "@stylistic/eslint-plugin": "5.10.0",
    "@tailwindcss/vite": "4.2.2",
    "eslint": "10.1.0",
    "eslint-plugin-astro": "1.6.0",
    "happy-dom": "20.8.9",
    "husky": "9.1.7",
    "secretlint": "11.4.0",
    "tailwindcss": "4.2.2",
    "typescript-eslint": "8.57.2",
    "vitest": "4.1.2"
  }
}
